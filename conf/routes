# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                           		controllers.Application.index

# JavaScript routes object
GET           /jsroutes.js                  controllers.JSController.jsRoutes()

# Core Application routes
GET           /messagingSocket              controllers.Application.messagingSocket()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file              			controllers.Assets.at(path="/public", file)

# TimeBooking
GET /booking/start/:userId/:categoryId/:projectId		controllers.TimeBookingController.start(userId:models.UserId, categoryId: models.CategoryId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
GET /booking/stop/:userId/:bookingId		controllers.TimeBookingController.stop(userId:models.UserId, bookingId:models.BookingId, end:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
GET /booking/remove/:userId/:bookingId		controllers.TimeBookingController.remove(userId:models.UserId, bookingId:models.BookingId)
GET /booking/append/:userId/:categoryId/:projectId		controllers.TimeBookingController.append(userId:models.UserId, categoryId: models.CategoryId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime, end:org.joda.time.DateTime)

# TimeBookingHistory
GET /history/:userId						controllers.TimeBookingHistoryController.getTimeBookingHistory(userId:models.UserId, from:org.joda.time.DateTime, to:org.joda.time.DateTime)

# CurrentUserTimeBookings
GET /current/:userId						controllers.CurrentUserTimeBookingsController.getCurrentTimeBooking(userId: models.UserId)

# StructureController
GET /structure/:userId						controllers.StructureController.getCategories(userId:models.UserId)

# Statistics
GET /stats/aggregated/bytags/:userId			controllers.TimeBookingStatisticsController.getAggregatedStatisticsByTagAndRange(userId:models.UserId, from:org.joda.time.DateTime, to:org.joda.time.DateTime)

# Static
# ~~~~
# Map static resources from the /public folder to the /assets URL path
GET           /assets/*file                 controllers.Assets.versioned(path="/public", file: Asset)

# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET     /                           controllers.Application.index

# JavaScript routes object
GET           /jsroutes.js                                   controllers.JSController.jsRoutes()

# Core Application routes
GET           /messagingSocket                               controllers.Application.messagingSocket()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.at(path="/public", file)

# TimeBooking
GET /booking/start/:userId/:projectId/		controllers.TimeBookingController.start(userId:models.UserId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
GET /booking/stop/:userId/:bookingId/	controllers.TimeBookingController.stop(userId:models.UserId, bookingId:models.BookingId, end:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
GET /booking/remove/:userId/:bookingId/	controllers.TimeBookingController.remove(userId:models.UserId, bookingId:models.BookingId)
GET /booking/append/:userId/:projectId/		controllers.TimeBookingController.append(userId:models.UserId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime, end:org.joda.time.DateTime)

# CurrentUserTimeBookings
GET /currentView/:userId				controllers.CurrentUserTimeBookingsController.index(userId: models.UserId)
GET /current/:userId				controllers.CurrentUserTimeBookingsController.getCurrentTimeBooking(userId: models.UserId)

# Static
# ~~~~
# Map static resources from the /public folder to the /assets URL path
GET           /assets/*file                                  controllers.Assets.versioned(path="/public", file: Asset)
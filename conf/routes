# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# Home page
GET      /                                      controllers.ApplicationController.index

# JavaScript routes object
GET      /jsroutes.js                           controllers.JSController.jsRoutes()

# Core Application routes
POST     /login                                 controllers.ApplicationController.login(email: String, password: String)
GET      /messagingSocket                       controllers.ApplicationController.messagingSocket()
POST     /logout                                controllers.ApplicationController.logout()

# Users
GET      /authuser                              controllers.UsersController.authUser()

# Map static resources from the /public folder to the /assets URL path
GET      /assets/*file                          controllers.Assets.at(path="/public", file)

# TimeBooking
POST     /mylasius/bookings/start               controllers.TimeBookingController.start(categoryId: models.CategoryId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
POST     /mylasius/bookings/stop                controllers.TimeBookingController.stop(bookingId:models.BookingId, end:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
POST     /mylasius/bookings/pause               controllers.TimeBookingController.pause(bookingId:models.BookingId, time:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
POST     /mylasius/bookings/resume              controllers.TimeBookingController.resume(bookingId:models.BookingId, time:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
POST     /mylasius/bookings/changeStart         controllers.TimeBookingController.changeStart(bookingId:models.BookingId, newStart:org.joda.time.DateTime ?= org.joda.time.DateTime.now())
DELETE   /mylasius/bookings/remove/:bookingId   controllers.TimeBookingController.remove(bookingId:models.BookingId)
POST     /mylasius/bookings/add              	controllers.TimeBookingController.add(categoryId: models.CategoryId, projectId: models.ProjectId, tags:Seq[models.TagId], start:org.joda.time.DateTime, end:org.joda.time.DateTime, comment:Option[String])
POST     /mylasius/bookings/edit                controllers.TimeBookingController.edit(bookingId:models.BookingId, start:org.joda.time.DateTime, end:org.joda.time.DateTime)

# TimeBookingHistory
GET      /mylasius/history                      controllers.TimeBookingHistoryController.getTimeBookingHistory(from:org.joda.time.DateTime, to:org.joda.time.DateTime)
GET      /mylasius/history/export               controllers.TimeBookingHistoryController.exportTimeBookingHistory(from:org.joda.time.DateTime, to:org.joda.time.DateTime)

# CurrentUserTimeBookings
GET      /mylasius/current                      controllers.CurrentUserTimeBookingsController.getCurrentTimeBooking()

# LatestUserTimeBookings
GET		/mylasius/latest						controllers.LatestUserTimeBookingsController.getLatestTimeBooking(maxHistory:Int?=5)

# StructureController
GET      /mylasius/structure                    controllers.StructureController.getCategories()

# Statistics
GET      /mylasius/stats/aggregated             controllers.TimeBookingStatisticsController.getAggregatedStatistics(source: String, from:org.joda.time.DateTime, to:org.joda.time.DateTime)
GET      /mylasius/stats/range                  controllers.TimeBookingStatisticsController.getStatistics(source: String, from:org.joda.time.DateTime, to:org.joda.time.DateTime)

# Favorites
GET      /mylasius/favorites/                   controllers.UserFavoritesController.getFavorites()
POST     /mylasius/favorites/add                controllers.UserFavoritesController.addFavorite(categoryId: models.CategoryId, projectId: models.ProjectId, tags: Seq[models.TagId])
DELETE   /mylasius/favorites/remove             controllers.UserFavoritesController.removeFavorite(categoryId: models.CategoryId, projectId: models.ProjectId, tags: Seq[models.TagId])

# Static
# ~~~~
# Map static resources from the /public folder to the /assets URL path
GET      /assets/*file                          controllers.Assets.versioned(path="/public", file: Asset)
